  {
    "id": "haios_why_files",
    "label": "Why Files",
    "parent": null,
    "intents": [],
    "tags": ["project", "deep"],
    "blocks": [
      { "type": "text", "content": "Message buses, databases, APIs \u2014 all infrastructure that breaks, costs money, and locks you in." },
      { "type": "text", "content": "Files are universal. Every LLM can read them. Every OS supports them. Git gives you versioning for free. The protocol IS the filesystem." },
      { "type": "callout", "text": "If your agent can\u2019t operate by reading and writing files, it\u2019s the agent that\u2019s limited \u2014 not the medium." }
    ],
    "chips": [
      { "label": "See the structure", "target": "haios_architecture" },
      { "label": "How memory works", "target": "haios_memory" }
    ]
  },
  {
    "id": "haios_architecture",
    "label": "HAIOS / Arch",
    "parent": "haios",
    "intents": ["file-based", "filesystem", "file structure"],
    "tags": ["project", "technical", "deep"],
    "blocks": [
      { "type": "text", "content": "No message bus. Coordination emerges from the file structure." },
      { "type": "code", "language": "structure", "content": "epochs/\n  arc-001/\n    chapter-001/\n      work-items/\n        WI-001.md\n      hindsight.md\n      reasoning-bank.md" },
      { "type": "text", "content": "If the file structure is the protocol, you don\u2019t need infrastructure. Any LLM that reads files can participate." }
    ],
